{
  "//": "spacing·radius·size·shadow·typography·grid 값은 디자인 확정 전 임시(placeholder)이며 확정 후 실제 값으로 교체한다. 간격은 정의된 키만 사용(PUBLISHING_CONVENTION PB-13). JSON은 주석 불가라 이 '//' 키로 메모하며, 생성기는 무시한다.",
  "scale": [0, 10, 30, 50, 70, 90, 100],
  "darkStrategy": "reflect",
  "primitive": {
    "gray": {
      "0": "#ffffff",
      "10": "#e6e8ea",
      "30": "#b1b8be",
      "50": "#6d7882",
      "70": "#464c53",
      "90": "#1e2124",
      "100": "#0a0a0a"
    },
    "red": {
      "0": "#fffdfd",
      "10": "#fcdfd9",
      "30": "#f48771",
      "50": "#de3412",
      "70": "#8a240f",
      "90": "#390d05",
      "100": "#030100"
    },
    "amber": {
      "0": "#fffefb",
      "10": "#ffe0a3",
      "30": "#ffb114",
      "50": "#9e6a00",
      "70": "#614100",
      "90": "#2e1f00",
      "100": "#020200"
    },
    "green": {
      "0": "#fdfefd",
      "10": "#d8eedd",
      "30": "#7ec88e",
      "50": "#228738",
      "70": "#285d33",
      "90": "#122b18",
      "100": "#010201"
    },
    "blue": {
      "0": "#fdfeff",
      "10": "#d8e5fd",
      "30": "#86aff9",
      "50": "#256ef4",
      "70": "#083891",
      "90": "#03163a",
      "100": "#000103"
    }
  },
  "alpha": {
    "white": [5, 10, 15, 20, 30],
    "black": [5, 10, 15, 20]
  },
  "semantic": {
    "background": { "light": "gray.0", "dark": "gray.100" },
    "foreground": "gray.90",
    "foreground-muted": "gray.70",
    "border": "gray.30",
    "surface": "gray.0",
    "brand": "blue.50",
    "brand-foreground": "blue.70",
    "danger": { "light": "red.50", "dark": "red.30" },
    "danger-surface": "red.10",
    "warning": { "light": "amber.50", "dark": "amber.30" },
    "warning-surface": "amber.10",
    "success": { "light": "green.50", "dark": "green.30" },
    "success-surface": "green.10",
    "info": { "light": "blue.50", "dark": "blue.30" },
    "info-surface": "blue.10",
    "scroll-thumb": "gray.30",
    "scroll-track": "gray.10"
  },

  "remBase": 16,
  "spacingBase": 4,

  "breakpoint": {
    "wide": 768,
    "pc": 1280
  },
  "typographyBreakpoint": "wide",

  "container": {
    "content": 1280
  },

  "grid": {
    "mobile": { "columns": 4, "gutter": 16, "margin": 16 },
    "wide": { "columns": 8, "gutter": 20, "margin": 24 },
    "pc": { "columns": 12, "gutter": 24, "margin": 32 }
  },

  "radius": {
    "none": 0,
    "sm": 6,
    "md": 8,
    "lg": 10,
    "xl": 12,
    "2xl": 16,
    "full": "9999px"
  },

  "size": {
    "icon-sm": 16,
    "icon-md": 20,
    "icon-lg": 24,
    "control-h-sm": 36,
    "control-h-md": 40,
    "control-h-lg": 48,
    "scrollbar-w": 6,
    "header-h": 64,
    "header-top": "header-h",
    "sidebar-w": 256,
    "sidebar-pl": "sidebar-w"
  },

  "//z": "z-index(레이어 순서) 토큰 → z-* 유틸(예: z-modal). 정수라 rem 변환 안 함. 값 자체가 아니라 '순서'가 의미이므로, 겹치는 UI를 추가하면 이 사다리 사이에 새 이름을 끼운다. header 는 앱 상단 바(z-header 로 명시), sticky 는 그 밖의 일반 고정 요소(툴바·섹션 헤더)다. 사이드 드로어는 아직 DOM 순서로 쌓인다(CD-002).",
  "z": {
    "base": 0,
    "dropdown": 1000,
    "sticky": 1100,
    "header": 1200,
    "drawer-backdrop": 1300,
    "drawer": 1400,
    "modal": 1500,
    "popover": 1600,
    "toast": 1700,
    "tooltip": 1800,
    "skiplink": 1900
  },

  "effect": {
    "shadow": {
      "1": {
        "x": 0,
        "y": 1,
        "blur": 3,
        "spread": 0,
        "color": { "light": "black.10", "dark": "white.15" }
      },
      "2": {
        "x": 0,
        "y": 4,
        "blur": 8,
        "spread": 0,
        "color": { "light": "black.10", "dark": "white.20" }
      },
      "3": {
        "x": 0,
        "y": 8,
        "blur": 16,
        "spread": 0,
        "color": { "light": "black.15", "dark": "white.30" }
      }
    },
    "blur": {
      "sm": 6,
      "md": 12,
      "lg": 20
    }
  },

  "overlay": {
    "sm": { "light": "black.5", "dark": "white.5" },
    "md": { "light": "black.10", "dark": "white.10" },
    "lg": { "light": "black.20", "dark": "white.20" }
  },

  "typography": {
    "heading-xl": {
      "size": { "mobile": 28, "pc": 36 },
      "weight": 700,
      "lineHeight": 1.3,
      "letterSpacing": "-0.02em"
    },
    "heading-lg": {
      "size": { "mobile": 24, "pc": 30 },
      "weight": 700,
      "lineHeight": 1.3,
      "letterSpacing": "-0.01em"
    },
    "heading-md": {
      "size": { "mobile": 20, "pc": 24 },
      "weight": 600,
      "lineHeight": 1.4,
      "letterSpacing": "0"
    },
    "heading-sm": {
      "size": { "mobile": 18, "pc": 20 },
      "weight": 600,
      "lineHeight": 1.4,
      "letterSpacing": "0"
    },
    "body-lg": {
      "size": { "mobile": 16, "pc": 18 },
      "weight": 400,
      "lineHeight": 1.6,
      "letterSpacing": "0"
    },
    "body-md": {
      "size": { "mobile": 15, "pc": 16 },
      "weight": 400,
      "lineHeight": 1.6,
      "letterSpacing": "0"
    },
    "body-sm": {
      "size": { "mobile": 13, "pc": 14 },
      "weight": 400,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "label": {
      "size": { "mobile": 13, "pc": 14 },
      "weight": 500,
      "lineHeight": 1.4,
      "letterSpacing": "0"
    },
    "caption": {
      "size": { "mobile": 12, "pc": 12 },
      "weight": 400,
      "lineHeight": 1.4,
      "letterSpacing": "0"
    }
  }
}
