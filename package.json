{
  "name": "kibo-ktop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "tokens": "node scripts/build-tokens.mjs",
    "asset-versions": "node scripts/compute-asset-versions.mjs",
    "predev": "yarn tokens && yarn asset-versions",
    "prebuild": "yarn tokens && yarn asset-versions",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:conventions": "node scripts/check-conventions.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "yarn tokens && yarn asset-versions && yarn lint && yarn format:check && yarn check:conventions && yarn typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
