{
    "name": "kibo-ktop",
    "version": "0.1.0",
    "private": true,
    "packageManager": "yarn@1.22.22",
    "scripts": {
        "tokens": "node scripts/build-tokens.mjs",
        "license-notices": "node scripts/generate-third-party-licenses.mjs",
        "license-notices:check": "node scripts/generate-third-party-licenses.mjs --check",
        "asset-versions": "node scripts/compute-asset-versions.mjs",
        "predev": "yarn tokens",
        "prebuild": "yarn tokens",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check:conventions": "node scripts/check-conventions.mjs",
        "typecheck": "next typegen && tsc --noEmit",
        "verify": "yarn tokens && yarn license-notices:check && yarn lint && yarn format:check && yarn check:conventions && yarn typecheck",
        "prepare": "husky"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "cytoscape": "3.34.0",
        "cytoscape-fcose": "2.2.0",
        "date-fns": "^4.4.0",
        "lottie-web": "^5.13.0",
        "lucide-react": "^1.23.0",
        "next": "16.2.9",
        "next-themes": "^0.4.6",
        "prism-react-renderer": "^2.4.1",
        "radix-ui": "^1.6.2",
        "react": "19.2.4",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.4",
        "recharts": "3.8.0",
        "shadcn": "^4.13.0",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "wordcloud": "1.2.3"
    },
    "devDependencies": {
        "@naverpay/prettier-config": "^1.0.1",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/wordcloud": "1.2.2",
        "eslint": "^9",
        "eslint-config-next": "16.2.9",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "husky": "^9.1.7",
        "prettier": "^3.9.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
