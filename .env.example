# 예시 환경변수 파일 — 실제 값은 .env.local 에 작성 (git 추적 제외)

# 사이트 절대 URL — 메타데이터(OG)·robots·sitemap 의 canonical/절대경로 생성에 사용
# 미설정 시 https://example.com 폴백
NEXT_PUBLIC_SITE_URL=https://example.com

# 저장소(GitHub 등) URL — 홈 화면 '저장소' 링크에 사용
# 미설정 시 예시 저장소로 폴백
NEXT_PUBLIC_REPOSITORY_URL=https://github.com/fromex-koh/kibo-ktop

# 백엔드 API 베이스 URL
# NEXT_PUBLIC_API_URL=http://localhost:3000
